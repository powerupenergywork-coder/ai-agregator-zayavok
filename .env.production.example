# Production .env for docker-compose.prod.yml — copy to `.env` on the server
# (/home/artur/aggregator/.env) and fill in the blanks. DATABASE_URL/REDIS_URL
# are NOT here on purpose — docker-compose.prod.yml sets those itself to the
# in-network postgres/redis hostnames, don't add them here or you'll override
# that with something that doesn't resolve inside the containers.
#
# Everything below WEB_URL/API_URL assumes nginx fronting on port 8002 with
# no domain yet (bare IP). Swap in a real domain later and rebuild the web
# image (NEXT_PUBLIC_API_URL is baked in at build time, not read at runtime).

# --- Core ---
NODE_ENV=production
API_PORT=3001
API_URL=http://85.159.24.131:8002/api
WEB_URL=http://85.159.24.131:8002
# Also passed as a docker build arg for the web image — see docker-compose.prod.yml.
NEXT_PUBLIC_API_URL=http://85.159.24.131:8002/api

# Generate with: openssl rand -hex 48
JWT_SECRET=REPLACE_ME

# --- Database (used to build DATABASE_URL inside docker-compose.prod.yml) ---
POSTGRES_USER=app
# Generate with: openssl rand -base64 24 | tr -dc 'a-zA-Z0-9' | head -c32
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=ai_zayavki

# --- Admin seed account (apps/api/prisma/seed.ts) ---
# Change these before running `prisma db seed` — the code defaults to
# admin@example.com/admin12345 if left blank, which you do NOT want live.
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=REPLACE_ME

# --- Auth / OTP ---
TRUSTED_DEVICE_DAYS=3
OTP_CODE_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# --- SMS provider ---
SMS_PROVIDER=console
# SMS_PROVIDER=mobizon
# MOBIZON_API_KEY=

# --- AI provider ---
AI_PROVIDER=mock
# AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# --- Storage ---
# local is fine for a first deploy — photos persist in the uploads_data
# docker volume. Switch to s3 later if you stand up real object storage.
STORAGE_PROVIDER=local
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=order-photos
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true

# --- Maps / geocoding ---
MAPS_PROVIDER=none
TWOGIS_API_KEY=

# --- Broadcast dispatch ---
DISPATCH_WAVE_SIZE=15

# --- Order completion check-in ---
ORDER_CHECKIN_DELAY_HOURS=24
ORDER_CHECKIN_ESCALATE_HOURS=48

# --- WhatsApp (GREEN-API) ---
WHATSAPP_PROVIDER=console
# WHATSAPP_PROVIDER=green-api
GREEN_API_BASE_URL=https://api.green-api.com
GREEN_API_ID_INSTANCE=
GREEN_API_TOKEN_INSTANCE=
# Generate with: openssl rand -hex 24
# Must match whatever you pass as webhookUrlToken when you run GREEN-API's
# SetSettings (see README).
WHATSAPP_WEBHOOK_TOKEN=REPLACE_ME

# --- Billing (supplier notification subscription) ---
PAYMENT_PROVIDER=mock
# PAYMENT_PROVIDER=kaspi
KASPI_MERCHANT_ID=
KASPI_API_KEY=
SUBSCRIPTION_PRICE_TENGE=5000
SUBSCRIPTION_PERIOD_DAYS=30
FREE_NOTIFICATIONS_PER_MONTH=10
