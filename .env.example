# --- Core ---
NODE_ENV=development
API_PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
JWT_SECRET=change-me-in-production

# --- Database / Queue ---
# Non-default host ports (5433/6380) — this machine already runs another
# Postgres/Redis stack on 5432/6379 for a different project (see docker-compose.yml).
DATABASE_URL=postgresql://app:app@localhost:5433/ai_zayavki
REDIS_URL=redis://localhost:6380

# --- Auth / OTP ---
# Trusted-device window: how long a phone stays verified on the same device without a new SMS code
TRUSTED_DEVICE_DAYS=3
OTP_CODE_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# --- SMS provider ---
# console = dev mode, logs the code to the API console instead of sending a real SMS
SMS_PROVIDER=console
# SMS_PROVIDER=mobizon
# MOBIZON_API_KEY=

# --- AI provider ---
# mock = deterministic offline classifier/extractor, no external calls, for local dev without a key
AI_PROVIDER=mock
# AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# --- Storage ---
# local = writes to apps/api/uploads and serves via /uploads static route, zero setup
# s3 = real S3-compatible upload (works with the MinIO from docker-compose)
STORAGE_PROVIDER=local
S3_ENDPOINT=http://localhost:9010
S3_REGION=us-east-1
S3_BUCKET=order-photos
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --- Maps / geocoding ---
# none = free-text address only, no geocoding
MAPS_PROVIDER=none
# MAPS_PROVIDER=2gis
TWOGIS_API_KEY=

# --- Broadcast dispatch (overridable by admin at runtime) ---
DISPATCH_WAVE_SIZE=15

# --- Order completion check-in (lead-broadcast model — see README) ---
ORDER_CHECKIN_DELAY_HOURS=24
ORDER_CHECKIN_ESCALATE_HOURS=48

# --- WhatsApp (GREEN-API) ---
# console = dev mode, logs outgoing messages instead of calling GREEN-API
WHATSAPP_PROVIDER=console
# WHATSAPP_PROVIDER=green-api
GREEN_API_BASE_URL=https://api.green-api.com
GREEN_API_ID_INSTANCE=
GREEN_API_TOKEN_INSTANCE=
# Checked against the Authorization header GREEN-API sends with every webhook
# (set the same value as webhookUrlToken when you run SetSettings — see README)
WHATSAPP_WEBHOOK_TOKEN=dev-webhook-token-change-me

# --- Billing (supplier notification subscription) ---
# mock = instant fake "payment" via GET /billing/mock-confirm/:reference, no real money involved
PAYMENT_PROVIDER=mock
# PAYMENT_PROVIDER=kaspi
KASPI_MERCHANT_ID=
KASPI_API_KEY=
# Placeholder values — not a real pricing decision, just what the mock charges
SUBSCRIPTION_PRICE_TENGE=5000
SUBSCRIPTION_PERIOD_DAYS=30
FREE_NOTIFICATIONS_PER_MONTH=10
